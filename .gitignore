# Secrets
.env
.env.local
*.pem
*.key

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
.pytest_cache/
.ruff_cache/
.mypy_cache/
*.egg-info/
build/
dist/

# Eval / training artifacts (large, ephemeral, never commit)
results/**/raw/
results/**/trajectories/
data/embeddings/*.faiss
data/embeddings/*.index
data/training/curated/*.jsonl
data/training/quarantine_audit.jsonl
# LazyGraphRAG build artifacts — regenerated by scripts/build_lazygraph_rag.py
data/lazygraph/
# Seed KG built artifact — produced by scripts/build_seed_kg.py from CSVs
data/seed_kg/graph.gpickle
data/seed_kg/expansions/*.gpickle
# Phase 1.5 raw-source working set (PDFs / HTML cached locally for chunking)
data/raw_pdfs/
# SSH TOFU artifacts (per-session host-key trust, NOT secrets but per-machine)
configs/ssh_known_hosts
# Reproducibility manifests captured at runtime — keep template + design;
# captured manifests accumulate and pile up per run. Promote noteworthy ones
# to docs/manifests/<id>.yaml when they're worth preserving.
reproducibility/captured/
nemo/checkpoints/
nemo/*.nemo
trt_engines/
*.engine

# Logs
*.log
nohup.out

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
third_party/
