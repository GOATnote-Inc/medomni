# prism42-nemotron-med — sovereign env template
#
# Two secrets total. If you find yourself adding more, re-read CLAUDE.md §2.
# The judge runs locally on H100. The serve runs locally on H200.
# Guardrails run locally. RAG runs locally. No cloud LLM keys belong here.

# ---------------------------------------------------------------------------
# Hugging Face — read-only, gated-model access for Llama-3.1-Nemotron-70B base.
# Provision a NEW token at https://huggingface.co/settings/tokens scoped to
# this repo only. DO NOT reuse the prod-shared token from /Users/kiteboard/lostbench/.env.
# ---------------------------------------------------------------------------
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---------------------------------------------------------------------------
# NGC registry — needed to pull NIM containers (nvcr.io/nim/...).
# Generate at https://ngc.nvidia.com/setup/api-key. Read-only registry creds,
# NOT a model API key. Provision new for this repo.
# ---------------------------------------------------------------------------
NGC_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NGC_CLI_API_KEY=${NGC_API_KEY}

# ---------------------------------------------------------------------------
# Brev SSH key — path to existing brev.pem on disk. Default location below.
# This is a path, not a secret value. The pem itself is not copied into env.
# ---------------------------------------------------------------------------
BREV_PEM_PATH=/Users/kiteboard/.brev/brev.pem

# ---------------------------------------------------------------------------
# Pod endpoints — set after Round-1 deploy. Local ssh-tunnel ports.
# These are NOT public URLs. NEVER point at *.thegoatnote.com or any DNS.
# Only ssh tunnels: ssh -L 8000:localhost:8000 warm-lavender-narwhal etc.
# ---------------------------------------------------------------------------
NEMOTRON_SERVE_URL=http://127.0.0.1:8000/v1
LLAMAGUARD_URL=http://127.0.0.1:8002/v1
NEMOTRON_REWARD_URL=http://127.0.0.1:8001
NV_EMBED_URL=http://127.0.0.1:8003/v1
